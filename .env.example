# QTI Launch Site — Environment Variables
# Copy to .env.local, NEVER commit .env.local

# Solana RPC endpoint (required for mainnet)
# Use a private RPC from Alchemy, Helius, or Triton
NEXT_PUBLIC_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Protocol fee vault ATA — the treasury token account that receives swap fees
# Run: spl-token create-account <QTI_MINT> --owner <SQUADS_VAULT>
NEXT_PUBLIC_FEE_VAULT=YOUR_FEE_VAULT_ATA_HERE

# Executioner program ID (post-deploy)
NEXT_PUBLIC_EXECUTIONER_PROGRAM_ID=ExecVx1RPJupAGGREGATORDeASI111111111111111

# ─── GitHub App — Issue Sync (Probot) ──────────────────────────────────────────
# Required: URL of the external issue tracker to forward GitHub issues to
EXTERNAL_TRACKER_URL=https://your-tracker.example.com/api/issues

# Required: API token for authenticating requests to the external tracker
EXTERNAL_TRACKER_TOKEN=your_tracker_api_token_here

# Optional: HTTP request timeout in milliseconds (default: 10000)
TRACKER_TIMEOUT_MS=10000

# Optional: Maximum number of retry attempts on transient failures (default: 3)
TRACKER_MAX_RETRIES=3

# Optional: Base delay in ms for exponential backoff between retries (default: 500)
TRACKER_RETRY_DELAY_MS=500
