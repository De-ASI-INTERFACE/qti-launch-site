# QTI Launch Site — Environment Variables
# Copy to .env.local, NEVER commit .env.local

# Solana RPC endpoint (required for mainnet)
# Use a private RPC from Alchemy, Helius, or Triton
NEXT_PUBLIC_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Protocol fee vault ATA — the treasury token account that receives swap fees
# Run: spl-token create-account <QTI_MINT> --owner <SQUADS_VAULT>
NEXT_PUBLIC_FEE_VAULT=YOUR_FEE_VAULT_ATA_HERE

# Executioner program ID (post-deploy)
NEXT_PUBLIC_EXECUTIONER_PROGRAM_ID=ExecVx1RPJupAGGREGATORDeASI111111111111111
